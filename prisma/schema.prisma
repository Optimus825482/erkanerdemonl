generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int       @id @default(autoincrement())
  username           String    @unique @db.VarChar(80)
  email              String    @unique @db.VarChar(120)
  passwordHash       String    @db.VarChar(255)
  role               UserRole  @default(ADMIN)
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  lastLogin          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model About {
  id              Int      @id @default(autoincrement())
  fullName        String   @default("Erkan Erdem")
  title           String   @default("Fullstack Developer & Veteriner Hekim")
  shortBio        String
  yaklasim        String
  felsefe         String
  profileImage    String   @default("/images/erkanerdem.png")
  email           String   @default("info@erkanerdem.net")
  website         String   @default("https://www.erkanerdem.net")
  location        String   @default("Türkiye")
  socialGithub    String?
  socialLinkedin  String?
  socialTwitter   String?
  socialInstagram String?
  heroTitles      Json
  heroImages      Json
  tags            Json
  technologies    Json
  interests       Json
  updatedAt       DateTime @updatedAt
  approach        String?
}

model Project {
  id              Int      @id @default(autoincrement())
  slug            String   @unique @db.VarChar(200)
  title           String   @db.VarChar(200)
  description     String
  longDescription String?
  category        String   @default("web")
  technologies    Json
  thumbnailImage  String
  contentImages   Json     @default("[]")
  videoUrl        String?
  githubUrl       String?
  liveUrl         String?
  status          String   @default("active")
  displayOrder    Int      @default(0)
  isFeatured      Boolean  @default(false)
  isPublished     Boolean  @default(true)
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Article {
  id             Int      @id @default(autoincrement())
  slug           String   @unique @db.VarChar(200)
  title          String   @db.VarChar(200)
  excerpt        String
  content        String
  category       String   @default("ai")
  tags           Json     @default("[]")
  thumbnailImage String
  authorName     String   @default("Erkan Erdem")
  isPublished    Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  publishedAt    DateTime @default(now())
  displayOrder   Int      @default(0)
  viewCount      Int      @default(0)
  readingTime    Int      @default(5)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Video {
  id              Int      @id @default(autoincrement())
  slug            String   @unique @db.VarChar(200)
  title           String   @db.VarChar(200)
  description     String
  longDescription String?
  category        String   @default("Yazılım Eğitimi")
  thumbnailImage  String   @default("/images/videos/placeholder.png")
  duration        String   @default("15:00")
  videoEmbed      String?
  isPublished     Boolean  @default(true)
  publishedAt     DateTime @default(now())
  displayOrder    Int      @default(0)
  viewCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FAQ {
  id           Int      @id @default(autoincrement())
  question     String
  answer       String
  colorTheme   String   @default("cyan")
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  email      String    @db.VarChar(120)
  subject    String?
  message    String
  isRead     Boolean   @default(false)
  isReplied  Boolean   @default(false)
  repliedAt  DateTime?
  adminNotes String?
  ipAddress  String?   @db.VarChar(45)
  userAgent  String?   @db.VarChar(255)
  createdAt  DateTime  @default(now())
}

model NewsletterSubscriber {
  id               Int      @id @default(autoincrement())
  email            String   @unique @db.VarChar(120)
  isActive         Boolean  @default(true)
  unsubscribeToken String   @unique @db.VarChar(64)
  createdAt        DateTime @default(now())
}

model Setting {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  value       String?
  valueType   String   @default("string")
  category    String   @default("general")
  description String?
  updatedAt   DateTime @updatedAt
}

enum UserRole {
  ADMIN
  EDITOR
}
